<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/iv_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="food"/>

    <!-- Gradient overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_feed_gradient"/>

    <!-- Type badge top right -->
    <TextView
        android:id="@+id/tv_type_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="80dp"
        android:text="✅ EAT"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:background="@drawable/bg_badge_eat"/>

    <!-- Bottom content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_feed_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍕"
                android:textSize="36sp"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_feed_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Food Name"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:shadowColor="#80000000"
                    android:shadowRadius="4"/>

                <TextView
                    android:id="@+id/tv_feed_cuisine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌍 Cuisine"
                    android:textColor="#CCffffff"
                    android:textSize="13sp"/>

            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_feed_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description..."
            android:textColor="#E0ffffff"
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="12dp"/>

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="#CC000000"
                app:cardCornerRadius="20dp">
                <TextView android:id="@+id/tv_feed_calories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 — kcal"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="#CC000000"
                app:cardCornerRadius="20dp">
                <TextView android:id="@+id/tv_feed_protein"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💪 —g protein"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#CC000000"
                app:cardCornerRadius="20dp">
                <TextView android:id="@+id/tv_feed_prep_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱️ — min"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Score row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView android:id="@+id/tv_health_score"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Health: 0/10"
                android:textColor="#E0ffffff"
                android:textSize="13sp"/>

            <TextView android:id="@+id/tv_taste_score"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Taste: 0/10"
                android:textColor="#E0ffffff"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_view_details"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="View Details"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="@color/white"
                app:cornerRadius="22dp"
                android:textColor="@color/primary"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_view_recipe"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="📖 Recipe"
                android:textSize="13sp"
                android:textStyle="bold"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/white"
                app:cornerRadius="22dp"
                android:textColor="@color/white"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
